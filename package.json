{
  "name": "gmail-phishing-detector",
  "version": "1.0.0",
  "description": "Real-time Gmail phishing & scam detection Chrome extension (100% local, no backend).",
  "type": "module",
  "scripts": {
    "build": "tsc -b --noEmit && npm run build:popup && npm run build:content && npm run build:background && npm run copy:static",
    "build:popup": "vite build --config vite.popup.config.ts",
    "build:content": "vite build --config vite.content.config.ts",
    "build:background": "vite build --config vite.background.config.ts",
    "copy:static": "node scripts/copy-static.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.1"
  }
}
